{
  "name": "home-build-planner",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "build:ci": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "depcruise": "depcruise src",
    "depcruise:report": "depcruise src --output-type err-html --output-to dependency-violation-report.html",
    "depcruise:graph": "depcruise src --output-type archi --output-to dependency-graph.dot",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test",
    "test:e2e:risk-01": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test e2e/risk-01-",
    "test:e2e:risk-02": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test e2e/risk-02-",
    "test:e2e:risk-04": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test e2e/risk-04-",
    "test:e2e:risk-07": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test e2e/risk-07-",
    "test:e2e:risk-08": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test e2e/risk-08-",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "benchmarks:import": "tsx scripts/import-market-benchmarks.ts",
    "db:reset-plans": "tsx prisma/reset-plans.ts",
    "db:docker:up": "docker compose up -d --wait",
    "db:docker:down": "docker compose down -v --rmi all --remove-orphans",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "googleapis": "^173.0.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "@emilbuszylo/ai-toolkit": "^0.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sentry/nextjs": "^10.56.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --max-warnings 0 --fix"
    ]
  }
}
