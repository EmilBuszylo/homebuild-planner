# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only (Supabase Secret key — future auth Server Actions)
SUPABASE_SECRET_KEY=

# Prisma / Postgres (server only)
#
# --- Supabase (preview/production) ---
# DATABASE_URL = Transaction pooler, port 6543, append ?pgbouncer=true
# DIRECT_URL = Direct connection, port 5432
#
# --- Local Docker (pnpm db:docker:up) — host port 55432, same URL for both vars ---
# DATABASE_URL=postgresql://homebuild:homebuild@127.0.0.1:55432/homebuild_planner
# DIRECT_URL=postgresql://homebuild:homebuild@127.0.0.1:55432/homebuild_planner
DATABASE_URL=
DIRECT_URL=
# Local `pnpm db:migrate` (migrate dev) is run by the repo owner only — not by agents.

# Plan recalculation rate limit (server only)
# PLAN_RECALC_LIMIT=3
# PLAN_RECALC_WINDOW_HOURS=24

# Market benchmarks import (owner-only: pnpm benchmarks:import)
# BENCHMARKS_JSON_URL=
