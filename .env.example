# Canonical public site URL — OAuth redirect_uri, server-side origin (set on Vercel Production too)
# Local: http://localhost:3000
# Production: https://homebuild-planner.vercel.app
# NEXT_PUBLIC_SITE_URL=

# Supabase Auth
# CI uses the same three vars as GitHub Actions secrets — see e2e/E2E-RULES.md §CI.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only (Supabase Secret key — auth Server Actions + E2E CI auto-confirm)
SUPABASE_SECRET_KEY=

# Prisma / Postgres (server only)
#
# --- Supabase (preview/production) ---
# DATABASE_URL = Transaction pooler, port 6543, append ?pgbouncer=true
# DIRECT_URL = Direct connection, port 5432
#
# --- Local Docker (pnpm db:docker:up) — host port 55432, same URL for both vars ---
# DATABASE_URL=postgresql://homebuild:homebuild@127.0.0.1:55432/homebuild_planner
# DIRECT_URL=postgresql://homebuild:homebuild@127.0.0.1:55432/homebuild_planner
DATABASE_URL=
DIRECT_URL=
# Local `pnpm db:migrate` (migrate dev) is run by the repo owner only — not by agents.

# Plan recalculation rate limit (server only)
# PLAN_RECALC_LIMIT=3
# PLAN_RECALC_WINDOW_HOURS=24

# Google Calendar export (FR-010 / S-04 — server only; required for OAuth + export after Phase 2)
# Create OAuth 2.0 Web client in Google Cloud Console; enable Google Calendar API.
# Authorized redirect URIs must match NEXT_PUBLIC_SITE_URL + /api/integrations/google/callback
# (see src/lib/site-origin.ts). Set NEXT_PUBLIC_SITE_URL on Vercel Production — do not rely on VERCEL_URL.
# Register every environment you use — mismatch causes Google error 400 redirect_uri_mismatch.
#   Local:       http://localhost:3000/api/integrations/google/callback
#   Production:  https://homebuild-planner.vercel.app/api/integrations/google/callback
#   Preview:     https://<preview-host>.vercel.app/api/integrations/google/callback
#                (each preview deployment has its own VERCEL_URL — add per preview or test on Production)
# Scope: https://www.googleapis.com/auth/calendar.events
# Set on Vercel Production (and Preview if testing OAuth there): GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET,
# GOOGLE_TOKEN_ENCRYPTION_KEY — same values as local .env.local.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# 32-byte key, base64 — e.g. openssl rand -base64 32 (encrypts refresh/access tokens at rest)
# GOOGLE_TOKEN_ENCRYPTION_KEY=

# Market benchmarks import (owner-only: pnpm benchmarks:import)
# BENCHMARKS_JSON_URL=

# Sentry (optional locally; set on Vercel Preview + Production for error monitoring)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=          # build-time source map upload (Production recommended)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_ENABLE_TEST_ROUTE=   # set to "true" on Preview to enable GET /api/health/sentry-test smoke

# GitHub Packages (@emilbuszylo/ai-toolkit) — optional locally if ~/.npmrc has read:packages token
# Required on Vercel (Preview + Production) and in GitHub Actions as secret GH_PKG_TOKEN
# GH_PKG_TOKEN=
