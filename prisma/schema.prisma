generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Singleton row for DB connectivity checks; not domain data.
model DbHealth {
  id        Int      @id @default(1)
  checkedAt DateTime @default(now()) @updatedAt
}
